# Examples of configuration files can be found here:
# https://juliu.is/a-simple-tmux/

source /usr/share/powerline/bindings/tmux/powerline.conf

## List of plugins

# Tmux Plugin Manager
# https://github.com/tmux-plugins/tpm
set -g @plugin 'tmux-plugins/tpm'

# basic tmux settings everyone can agree on
# https://github.com/tmux-plugins/tmux-sensible
set -g @plugin 'tmux-plugins/tmux-sensible'

set -g @plugin 'tmux-plugins/tmux-yank'

# Persist Sessio over reboots
# set -g @plugin 'tmux-plugins/tmux-resurrect'
# set -g @plugin 'tmux-plugins/tmux-continuum'
# set -g @continuum-boot 'on'
# set -g @continuum-restore 'on'
# set -g @continuum-save-interval '1'
## set -g @continuum-boot-options 'kitty'
## for neovim
# set -g @resurrect-strategy-nvim 'session'
# set -g status-right 'Continuum status: #{continuum_status}'

set -g mouse on
set-option -g history-limit 100000

# Name pane with pane_current_path
set-option -g status-interval 5
set-option -g automatic-rename on
set-option -g automatic-rename-format '#{b:pane_current_path}'

# enable scrolling using the Shift-PageUp/Down keys:
# it enters and exits copy-mode automatically. 
# Also it scrolls half page which i find more convenient
bind -n S-Up copy-mode -e \; send-keys -X scroll-up
bind -n S-Down copy-mode -e \; send-keys -X scroll-down
bind -n S-Pageup copy-mode -e \; send-keys -X halfpage-up
bind -n S-Pagedown copy-mode -e \; send-keys -X halfpage-down

# set -g @yank_selection 'secondary'
# set -g @yank_selection_mouse 'secondary'
# Use wl-copy for copying when text is selected with the mouse
# bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel 'wl-copy'
# Use wl-paste for pasting with the middle mouse button
# bind-key -n MouseDown2Pane run-shell -b "wl-paste | tmux load-buffer - && tmux paste-buffer"
# bind-key -T root MouseDown2Pane run-shell -b "wl-paste | tmux load-buffer - && tmux paste-buffer"


# Initialize TMUX plugin manager (keep this line at the very bottom of tmux.conf)
run '~/.tmux/plugins/tpm/tpm'

