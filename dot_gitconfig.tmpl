[user]
  name = {{ .name }}
  email = {{ .email }}
[core]
	editor = nvim
	pager = /usr/bin/less -R -F -X
[merge]
	tool = meld
[color]
	status = auto
	branch = auto
	interactive = auto
	diff = auto
[alias]
	co = checkout
	br = branch
	st = status
	ci = commit
	unstage = reset HEAD --
	ls = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate
	ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
[push]
	autoSetupRemote = true
[init]
	defaultBranch = main
[pull]
	rebase = true
[pager]
	branch = true
[credential]
	helper = cache --timeout=36000
